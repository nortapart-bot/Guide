<script>
// Reveal on scroll
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target)}})
},{threshold:.12});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

// Nav dots
const dots=document.querySelectorAll('.nav-dot');
const secs=Array.from(dots).map(d=>document.getElementById(d.dataset.slide));
function updateDots(){
  let idx=0;const mid=window.innerHeight/2;
  secs.forEach((s,i)=>{if(s&&s.getBoundingClientRect().top<=mid)idx=i});
  dots.forEach((d,i)=>d.classList.toggle('active',i===idx));
}
window.addEventListener('scroll',updateDots,{passive:true});
dots.forEach(d=>d.addEventListener('click',()=>{
  const el=document.getElementById(d.dataset.slide);
  if(el)el.scrollIntoView({behavior:'smooth'});
}));

// Smooth scroll for anchor links
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{
    e.preventDefault();
    const t=document.querySelector(a.getAttribute('href'));
    if(t)t.scrollIntoView({behavior:'smooth'});
  });
});
</script>
